# ⭐ EXEMPLE DE FICHIER .env ⭐
# Copie ce fichier en .env et remplis tes vraies valeurs!

# Telegram Bot Token (va sur @BotFather pour l'obtenir)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Discord Bot Token (optionnel - si tu veux un bot Discord)
DISCORD_BOT_TOKEN=ton_token_discord_ici

# URL de ton catalogue de sites
CATALOGUE_URL=https://example.com/catalogue

# Paramètres optionnels
MAX_SEARCH_RESULTS=20
RATE_LIMIT_DELAY=1
